# =============================================
# 서버 2 설정 — 이 파일을 .env 로 복사하여 사용
# =============================================

# 클러스터 공통 (세 서버 모두 동일한 값 사용)
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# 이 노드 고유 설정
NODE_ID=2
NODE_HOST=10.0.1.12        # 이 서버의 실제 IP 또는 도메인으로 변경
EXTERNAL_PORT=9092

# 세 서버의 IP:포트를 모두 기입 (세 서버 동일)
QUORUM_VOTERS=1@10.0.1.11:9093,2@10.0.1.12:9093,3@10.0.1.13:9093
