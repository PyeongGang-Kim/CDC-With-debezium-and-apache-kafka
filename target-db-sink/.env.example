# Debezium 커넥터 버전 (Docker 빌드 시 ARG로 전달)
# plugins/ 에 동일 버전의 tar.gz 파일이 있어야 함
DEBEZIUM_VERSION=3.0.0.Final

# 타겟 Oracle RAC
TARGET_ORACLE_NODE1=192.168.2.101
TARGET_ORACLE_NODE2=192.168.2.102
TARGET_ORACLE_PORT=1521
TARGET_ORACLE_SERVICE_NAME=TGTORCL
TARGET_ORACLE_USER=cdc_target
TARGET_ORACLE_PASSWORD=ChangeMe_2024!

# ── Upsert 커넥터 (PK 또는 message.key.columns 로 키가 지정된 테이블) ──────────
# 소스 커넥터의 TABLE_INCLUDE_LIST + MESSAGE_KEY_COLUMNS 로 키가 확정된 테이블만 포함
UPSERT_TOPICS=oracle.MYSCHEMA.ORDERS,oracle.MYSCHEMA.CUSTOMERS,oracle.MYSCHEMA.PRODUCTS

# ── Insert-only 커넥터 (키 컬럼을 특정할 수 없는 PK-less 테이블) ──────────────
# 소스에서 MESSAGE_KEY_COLUMNS 로도 키를 지정할 수 없는 테이블만 여기에 포함
# DELETE 이벤트는 무시됨 (키 없이 대상 행 특정 불가)
INSERT_ONLY_TOPICS=oracle.MYSCHEMA.AUDIT_LOG
