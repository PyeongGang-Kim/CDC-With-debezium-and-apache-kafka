{
  "name": "oracle-rac-cdc-connector",
  "config": {
    "connector.class": "io.debezium.connector.oracle.OracleConnector",
    "tasks.max": "1",

    "database.hostname": "${ORACLE_SCAN_HOST}",
    "database.port": "${ORACLE_PORT}",
    "database.user": "${ORACLE_LOGMINER_USER}",
    "database.password": "${ORACLE_LOGMINER_PASSWORD}",
    "database.dbname": "${ORACLE_CDB_NAME}",
    "database.pdb.name": "${ORACLE_PDB_NAME}",

    "database.url": "jdbc:oracle:thin:@(DESCRIPTION=(LOAD_BALANCE=on)(FAILOVER=on)(ADDRESS=(PROTOCOL=TCP)(HOST=${ORACLE_RAC_NODE1})(PORT=${ORACLE_PORT}))(ADDRESS=(PROTOCOL=TCP)(HOST=${ORACLE_RAC_NODE2})(PORT=${ORACLE_PORT}))(CONNECT_DATA=(SERVICE_NAME=${ORACLE_SERVICE_NAME})(SERVER=DEDICATED)))",

    "topic.prefix": "oracle",

    "schema.history.internal.kafka.bootstrap.servers": "${KAFKA_BOOTSTRAP_SERVERS}",
    "schema.history.internal.kafka.topic": "oracle.schema-history",

    "_comment_tables": "CDC 대상 전체 테이블 목록 (콤마 구분, SCHEMA.TABLE 형식)",
    "table.include.list": "${TABLE_INCLUDE_LIST}",

    "_comment_snapshot_include": [
      "초기 스냅샷을 실행할 테이블만 지정 (table.include.list 의 부분집합).",
      "이 목록에 없는 테이블은 스냅샷 없이 CDC 스트리밍만 적용됨.",
      "빈 값으로 두면 table.include.list 전체가 스냅샷 대상."
    ],
    "snapshot.include.collection.list": "${SNAPSHOT_INCLUDE_LIST}",

    "_comment_message_key": [
      "PK 없는 테이블에 대해 Kafka 레코드 키로 사용할 컬럼을 직접 지정.",
      "형식: SCHEMA1.TABLE1:col1,col2;SCHEMA2.TABLE2:col3",
      "지정한 컬럼 조합이 싱크 측 upsert/delete 의 WHERE 조건으로 사용됨.",
      "PK 있는 테이블은 자동으로 PK 컬럼이 키로 설정되므로 생략 가능."
    ],
    "message.key.columns": "${MESSAGE_KEY_COLUMNS}",

    "_comment_signal": [
      "Signal 채널: 커넥터 실행 중 특정 테이블에만 ad-hoc 스냅샷을 트리거.",
      "scripts/adhoc-snapshot.sh 를 사용해 신호를 전송."
    ],
    "signal.enabled.channels": "kafka",
    "signal.kafka.topic": "oracle.signals",
    "signal.kafka.bootstrap.servers": "${KAFKA_BOOTSTRAP_SERVERS}",
    "signal.kafka.group.id": "oracle-signal-group",

    "log.mining.strategy": "online_catalog",
    "log.mining.batch.size.max": "20000",
    "log.mining.sleep.time.max.ms": "3000",
    "log.mining.transaction.retention.ms": "86400000",

    "snapshot.mode": "initial",
    "snapshot.locking.mode": "none",
    "snapshot.fetch.size": "2000",

    "decimal.handling.mode": "string",
    "time.precision.mode": "connect",
    "binary.handling.mode": "base64",

    "heartbeat.interval.ms": "10000",

    "rac.nodes": "${ORACLE_RAC_NODE1},${ORACLE_RAC_NODE2}",

    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "true",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "true",

    "errors.log.enable": "true",
    "errors.log.include.messages": "true",
    "errors.tolerance": "none",

    "tombstones.on.delete": "true",

    "poll.interval.ms": "1000",
    "max.batch.size": "2048",
    "max.queue.size": "8192"
  }
}
