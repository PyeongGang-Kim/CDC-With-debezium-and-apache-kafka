# Oracle RAC 소스 DB 설정
ORACLE_SCAN_HOST=oracle-rac-scan.example.com
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=MYORCL
ORACLE_CDB_NAME=CDB1
ORACLE_PDB_NAME=PDB1

# Oracle RAC 노드 IP (LogMiner 모드에서 Redo Log 직접 접근용)
ORACLE_RAC_NODE1=192.168.1.101
ORACLE_RAC_NODE2=192.168.1.102

# Debezium CDC 전용 계정 (LogMiner, XStream 공통)
ORACLE_LOGMINER_USER=c##dbzuser
ORACLE_LOGMINER_PASSWORD=dbzpassword

# Kafka 연결
KAFKA_BOOTSTRAP_SERVERS=kafka-1:9092,kafka-2:9092,kafka-3:9092

# Debezium 커넥터 버전 (Docker 빌드 시 ARG로 전달)
# plugins/ 에 동일 버전의 tar.gz 파일이 있어야 함
DEBEZIUM_VERSION=3.0.0.Final

# ── CDC 방식 선택 ────────────────────────────────────────────────────────────
# logminer (기본값): Oracle LogMiner 기반. 별도 라이선스 불필요.
# xstream:          Oracle XStream 기반. Oracle GoldenGate 라이선스 필요.
#                   LogMiner 대비 낮은 지연 시간 제공.
CDC_METHOD=logminer

# XStream 모드 전용 설정 (CDC_METHOD=xstream 일 때만 사용)
# Oracle XStream Outbound Server 이름 (oracle-setup.sql 에서 생성한 이름)
XSTREAM_OUT_SERVER_NAME=dbzxout

# ── CDC 대상 테이블 ──────────────────────────────────────────────────────────
# CDC 대상 전체 테이블 (SCHEMA.TABLE 형식, 콤마 구분)
TABLE_INCLUDE_LIST=MYSCHEMA.ORDERS,MYSCHEMA.CUSTOMERS,MYSCHEMA.PRODUCTS,MYSCHEMA.AUDIT_LOG

# 초기 스냅샷 대상 테이블 (TABLE_INCLUDE_LIST 의 부분집합)
# 이 목록에 없는 테이블은 CDC 스트리밍만 적용 (스냅샷 없음)
# 전체 스냅샷이 필요하면 TABLE_INCLUDE_LIST 와 동일하게 설정
SNAPSHOT_INCLUDE_LIST=MYSCHEMA.ORDERS,MYSCHEMA.CUSTOMERS,MYSCHEMA.PRODUCTS

# PK 없는 테이블의 유효 키 컬럼 지정 (형식: SCHEMA.TABLE:col1,col2;...)
# PK 있는 테이블은 자동으로 PK 를 키로 사용하므로 생략 가능
MESSAGE_KEY_COLUMNS=MYSCHEMA.AUDIT_LOG:TX_ID,SEQ_NO
